# Maintainer: Lakshman Patel <GrayCodeAI@users.noreply.github.com>
pkgname=tok
pkgver=0.0.0
pkgrel=1
pkgdesc="Transparent command-output filter that reduces LLM token consumption"
arch=('x86_64' 'aarch64')
url="https://github.com/GrayCodeAI/tok"
license=('MIT')
makedepends=('go')
source=("git+https://github.com/GrayCodeAI/tok.git")
sha256sums=('SKIP')

pkgver() {
  cd "${pkgname}"
  # Prefer the latest semver-ish tag; fall back to a dated commit count.
  git describe --tags --always 2>/dev/null | sed 's/^v//;s/-/./g' || \
    printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

build() {
  cd "${pkgname}"
  export CGO_ENABLED=0
  export GOFLAGS="-trimpath -mod=readonly -modcacherw"
  go build -ldflags="-s -w" -o "${pkgname}" ./cmd/tok
}

package() {
  cd "${pkgname}"
  install -Dm755 "${pkgname}" "${pkgdir}/usr/bin/${pkgname}"
  install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE" 2>/dev/null || true
  install -Dm644 README.md "${pkgdir}/usr/share/doc/${pkgname}/README.md" 2>/dev/null || true
}
