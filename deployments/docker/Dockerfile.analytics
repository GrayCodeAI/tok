# TokMan Analytics Service - Metrics & Tracking
FROM golang:1.22-alpine AS builder

WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /analytics-service ./cmd/tokman-server

FROM alpine:3.19
RUN apk --no-cache add ca-certificates sqlite
COPY --from=builder /analytics-service /analytics-service

EXPOSE 50053 8083
ENTRYPOINT ["/analytics-service"]
CMD ["--service=analytics"]
