cff-version: 1.2.0
title: "Tok: Token-Aware CLI Proxy with 31-Layer Compression Pipeline"
message: "If you use Tok in your research, please cite it using these metadata."
type: software
authors:
  - name: "GrayCode AI"
    website: "https://github.com/lakshmanpatel"
repository-code: "https://github.com/lakshmanpatel/tok"
url: "https://github.com/lakshmanpatel/tok"
license: MIT
version: "0.28.2"
date-released: "2026-04-03"
keywords:
  - token-reduction
  - llm
