{
  "name": "tokman",
  "displayName": "TokMan Token Optimizer",
  "description": "Reduce token usage in AI coding assistant interactions",
  "version": "0.28.2",
  "publisher": "GrayCodeAI",
  "author": "Lakshman Patel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/GrayCodeAI/tokman"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other",
    "Developer Tools",
    "Extension Packs"
  ],
  "keywords": [
    "tokens",
    "ai",
    "llm",
    "compression",
    "optimization",
    "claude",
    "cursor"
  ],
  "icon": "icons/icon.png",
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "activationEvents": [
    "onLanguage:shell",
    "onLanguage:json",
    "onLanguage:yaml",
    "onLanguage:markdown",
    "workspaceContains:**/.tokman.yaml",
    "command:tokman.init"
  ],
  "main": "./src/extension",
  "contributes": {
    "commands": [
      {
        "command": "tokman.init",
        "title": "TokMan: Initialize",
        "category": "TokMan",
        "description": "Initialize TokMan with current IDE"
      },
      {
        "command": "tokman.enable",
        "title": "TokMan: Enable",
        "category": "TokMan",
        "description": "Enable TokMan token optimization"
      },
      {
        "command": "tokman.disable",
        "title": "TokMan: Disable",
        "category": "TokMan",
        "description": "Disable TokMan token optimization"
      },
      {
        "command": "tokman.status",
        "title": "TokMan: Status",
        "category": "TokMan",
        "description": "Show TokMan status"
      },
      {
        "command": "tokman.stats",
        "title": "TokMan: Statistics",
        "category": "TokMan",
        "description": "Show token savings statistics"
      },
      {
        "command": "tokman.dashboard",
        "title": "TokMan: Dashboard",
        "category": "TokMan",
        "description": "Open web dashboard"
      },
      {
        "command": "tokman.config",
        "title": "TokMan: Configuration",
        "category": "TokMan",
        "description": "Open configuration file"
      },
      {
        "command": "tokman.compressTest",
        "title": "TokMan: Test Compression",
        "category": "TokMan",
        "description": "Test compression on selection"
      },
      {
        "command": "tokman.setBudget",
        "title": "TokMan: Set Token Budget",
        "category": "TokMan",
        "description": "Set token budget for output"
      },
      {
        "command": "tokman.setProfile",
        "title": "TokMan: Set Profile",
        "category": "TokMan",
        "description": "Set compression profile (fast/balanced/full)"
      }
    ],
    "keybindings": [
      {
        "command": "tokman.status",
        "key": "ctrl+shift+t",
        "mac": "cmd+shift+t",
        "when": "editorTextFocus"
      },
      {
        "command": "tokman.toggle",
        "key": "ctrl+shift+o",
        "mac": "cmd+shift+o",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "TokMan",
      "properties": {
        "tokman.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable TokMan token optimization"
        },
        "tokman.budget": {
          "type": "number",
          "default": 2000,
          "description": "Maximum tokens allowed in command output (0 = unlimited)"
        },
        "tokman.profile": {
          "type": "string",
          "enum": ["fast", "balanced", "full"],
          "default": "balanced",
          "description": "Compression profile preset"
        },
        "tokman.mode": {
          "type": "string",
          "enum": ["minimal", "aggressive"],
          "default": "minimal",
          "description": "Filter mode (minimal preserves more, aggressive compresses more)"
        },
        "tokman.ultraCompact": {
          "type": "boolean",
          "default": false,
          "description": "Ultra-compact mode with ASCII icons and minimal formatting"
        },
        "tokman.verbose": {
          "type": "boolean",
          "default": false,
          "description": "Show verbose output for debugging"
        },
        "tokman.dashboardPort": {
          "type": "number",
          "default": 8080,
          "description": "Port for web dashboard"
        },
        "tokman.llmEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable LLM-based compression (requires Ollama/LM Studio)"
        },
        "tokman.compactionEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable semantic compaction for chat content"
        },
        "tokman.h2oEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable H2O heavy-hitter filter"
        },
        "tokman.attentionSinkEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable attention sink for context stability"
        },
        "tokman.terminalIntegration": {
          "type": "boolean",
          "default": true,
          "description": "Auto-intercept terminal commands"
        },
        "tokman.excludedCommands": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Commands to exclude from filtering"
        },
        "tokman.includePatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": ["**/*"],
          "description": "File patterns to include in compression"
        },
        "tokman.excludePatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": ["**/node_modules/**", "**/.git/**"],
          "description": "File patterns to exclude from compression"
        }
      }
    },
    "views": {
      "explorer": [
        {
          "id": "tokman.views.stats",
          "name": "TokMan Stats"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tokman-activity",
          "title": "TokMan",
          "icon": "icons/icon.png"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "tokman.init",
          "when": "workspaceContains:**/*"
        }
      ],
      "editor/context": [
        {
          "command": "tokman.compressTest",
          "when": "editorHasSelection"
        }
      ],
      "view/title": [
        {
          "command": "tokman.refresh",
          "group": "navigation",
          "where": "tokman.views.stats"
        }
      ]
    },
    "problemMatchers": [
      {
        "name": "tokman",
        "owner": "tokman",
        "fileLocation": "absolute",
        "pattern": {
          "regexp": "^\\[TokMan\\] (.+)$",
          "message": 1
        },
        "severity": "info"
      }
    ],
    "taskDefinitions": [
      {
        "type": "tokman",
        "required": ["command"],
        "properties": {
          "command": {
            "type": "string",
            "description": "The command to run with TokMan"
          },
          "budget": {
            "type": "number",
            "description": "Token budget for output"
          },
          "profile": {
            "type": "string",
            "description": "Compression profile"
          }
        }
      }
    ],
    "languages": [
      {
        "id": "tokman-output",
        "extensions": [".tokman"],
        "aliases": ["TokMan Output"]
      }
    ],
    "grammars": [
      {
        "language": "tokman-output",
        "scopeName": "source.tokman-output",
        "path": "./syntaxes/tokman-output.json"
      }
    ],
    "snippets": [
      {
        "language": "shell",
        "path": "./snippets/shell.json"
      }
    ],
    "jsonValidation": [
      {
        "fileMatch": ".tokman.json",
        "url": "./schemas/tokman-config.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./tsconfig.json",
    "watch": "tsc -watch -p ./tsconfig.json",
    "test": "node ./out/test/runTest.js",
    "lint": "eslint src --ext .ts",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "@types/mocha": "^10.0.0",
    "@vscode/test-electron": "^2.3.0",
    "eslint": "^8.45.0",
    "typescript": "^5.0.0",
    "vsce": "^2.0.0"
  },
  "dependencies": {
    "vscode": "^1.80.0"
  },
  "extensionDependencies": [],
  "extensionPack": [],
  "badges": [
    {
      "url": "https://img.shields.io/github/v/release/GrayCodeAI/tokman",
      "href": "https://github.com/GrayCodeAI/tokman/releases",
      "description": "Version"
    },
    {
      "url": "https://img.shields.io/github/license/GrayCodeAI/tokman",
      "href": "LICENSE",
      "description": "License: MIT"
    }
  ]
}