# Maintainer: GrayCodeAI <https://github.com/GrayCodeAI>
# Contributor: lpatel

pkgname=tokman-bin
pkgver=1.1.0
pkgrel=1
pkgdesc="Token-aware CLI proxy for LLM interactions"
arch=('x86_64' 'aarch64')
url="https://github.com/GrayCodeAI/tokman"
license=('MIT')
depends=('glibc')
optdepends=(
  'git: for git command wrappers'
  'docker: for docker command wrappers'
  'kubectl: for kubernetes command wrappers'
  'nodejs: for npm/pnpm/npx wrappers'
  'python: for pip/pytest/mypy wrappers'
  'rust: for cargo wrappers'
  'go: for go command wrappers'
)
provides=('tokman')
conflicts=('tokman' 'tokman-git')
source_x86_64=("tokman-${pkgver}-linux-amd64.tar.gz::${url}/releases/download/v${pkgver}/tokman-linux-amd64.tar.gz")
source_aarch64=("tokman-${pkgver}-linux-arm64.tar.gz::${url}/releases/download/v${pkgver}/tokman-linux-arm64.tar.gz")
sha256sums_x86_64=('PLACEHOLDER_LINUX_AMD64_SHA256')
sha256sums_aarch64=('PLACEHOLDER_LINUX_ARM64_SHA256')

package() {
  install -Dm755 tokman "${pkgdir}/usr/bin/tokman"
  
  # Install shell completions
  install -Dm644 completions/tokman.bash "${pkgdir}/usr/share/bash-completion/completions/tokman"
  install -Dm644 completions/tokman.zsh "${pkgdir}/usr/share/zsh/site-functions/_tokman"
  install -Dm644 completions/tokman.fish "${pkgdir}/usr/share/fish/vendor_completions.d/tokman.fish"
  
  # Install license
  install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/tokman/LICENSE"
  
  # Install README
  install -Dm644 README.md "${pkgdir}/usr/share/doc/tokman/README.md"
}
