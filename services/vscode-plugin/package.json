{
  "name": "tokman-vscode",
  "displayName": "TokMan - Token Usage Analytics",
  "description": "Real-time token usage analytics and compression preview for Claude, ChatGPT, and other AI assistants",
  "version": "1.0.0",
  "publisher": "GrayCodeAI",
  "license": "MIT",
  "icon": "assets/icon.png",
  "engines": {
    "vscode": "^1.84.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "tokens",
    "compression",
    "analytics",
    "claude",
    "chatgpt",
    "ai-assistant"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/GrayCodeAI/tokman"
  },
  "bugs": {
    "url": "https://github.com/GrayCodeAI/tokman/issues"
  },
  "homepage": "https://tokman.dev",
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "tokman.analyzeSelection",
        "title": "TokMan: Analyze Selection",
        "description": "Analyze token usage of selected code"
      },
      {
        "command": "tokman.analyzeFile",
        "title": "TokMan: Analyze File",
        "description": "Analyze token usage of current file"
      },
      {
        "command": "tokman.togglePreview",
        "title": "TokMan: Toggle Real-time Preview",
        "description": "Toggle real-time token preview"
      },
      {
        "command": "tokman.sendToClaude",
        "title": "TokMan: Send to Claude",
        "description": "Send compressed content to Claude"
      },
      {
        "command": "tokman.openDashboard",
        "title": "TokMan: Open Analytics Dashboard",
        "description": "Open the TokMan analytics dashboard"
      },
      {
        "command": "tokman.settings",
        "title": "TokMan: Settings",
        "description": "Open TokMan settings"
      }
    ],
    "keybindings": [
      {
        "command": "tokman.analyzeSelection",
        "key": "ctrl+shift+t",
        "mac": "cmd+shift+t",
        "when": "editorTextFocus"
      },
      {
        "command": "tokman.togglePreview",
        "key": "ctrl+shift+p",
        "mac": "cmd+shift+p",
        "when": "editorTextFocus"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "tokman.analyzeSelection",
          "group": "1_modification",
          "when": "editorTextFocus"
        },
        {
          "command": "tokman.sendToClaude",
          "group": "1_modification",
          "when": "editorTextFocus && editorHasSelection"
        }
      ],
      "commandPalette": [
        {
          "command": "tokman.analyzeSelection",
          "when": "editorTextFocus"
        },
        {
          "command": "tokman.analyzeFile",
          "when": "editorTextFocus"
        },
        {
          "command": "tokman.togglePreview",
          "when": "editorTextFocus"
        },
        {
          "command": "tokman.sendToClaude",
          "when": "editorTextFocus"
        },
        {
          "command": "tokman.openDashboard"
        },
        {
          "command": "tokman.settings"
        }
      ]
    },
    "configuration": {
      "title": "TokMan",
      "properties": {
        "tokman.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable TokMan extension"
        },
        "tokman.realtimePreview": {
          "type": "boolean",
          "default": true,
          "description": "Show real-time token preview on hover"
        },
        "tokman.apiEndpoint": {
          "type": "string",
          "default": "http://localhost:8083",
          "description": "TokMan API endpoint URL"
        },
        "tokman.tokenCounterModel": {
          "type": "string",
          "enum": [
            "claude-3-5-sonnet",
            "claude-3-opus",
            "gpt-4-turbo",
            "gpt-3.5-turbo"
          ],
          "default": "claude-3-5-sonnet",
          "description": "Model to use for token counting"
        },
        "tokman.showInlineDecorations": {
          "type": "boolean",
          "default": true,
          "description": "Show inline token count decorations in editor"
        },
        "tokman.showComparisonBefore": {
          "type": "boolean",
          "default": true,
          "description": "Show compression ratio comparison in status bar"
        },
        "tokman.compressionLevel": {
          "type": "string",
          "enum": [
            "minimal",
            "aggressive"
          ],
          "default": "aggressive",
          "description": "Compression level for preview"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tokman-view",
          "title": "TokMan",
          "icon": "assets/icon.svg"
        }
      ]
    },
    "views": {
      "tokman-view": [
        {
          "id": "tokman.statsView",
          "name": "Token Stats",
          "description": "Current session token statistics"
        },
        {
          "id": "tokman.historyView",
          "name": "Analysis History",
          "description": "Recent token analyses"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.84.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.50.0",
    "typescript": "^5.3.0",
    "vsce": "^2.15.0"
  },
  "dependencies": {
    "axios": "^1.6.0"
  }
}
