# TokMan - Development Docker Image
# Includes full Go toolchain for development

FROM golang:1.21-alpine

# Install development tools
RUN apk add --no-cache \
    git \
    ca-certificates \
    make \
    gcc \
    musl-dev \
    curl \
    bash \
    vim \
    sqlite

# Install Go tools
RUN go install github.com/golangci/golangci-lint/cmd/golangci-lint@latest && \
    go install golang.org/x/tools/cmd/goimports@latest && \
    go install github.com/fzipp/gocyclo/cmd/gocyclo@latest

# Set working directory
WORKDIR /app

# Copy go mod files
COPY go.mod go.sum ./
RUN go mod download

# Copy source code
COPY . .

# Set environment
ENV GO111MODULE=on
ENV CGO_ENABLED=1

# Default command
CMD ["/bin/sh"]
